{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and stats",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "xp": { "type": "number" },
        "level": { "type": "number" },
        "streak": { "type": "number" },
        "correct": { "type": "number" },
        "difficulty": { "type": "number" },
        "profileAvatar": { "type": "string" },
        "currentYear": { "type": "string" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "xp", "level", "profileAvatar"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    }
  }
}
